{
    "name": "traccykay/medishield",
    "description": "MediShield - Secure Healthcare Records Management System with cybersecurity and forensic audit logging (XAMPP / PHP / MySQL).",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "phpmailer/phpmailer": "^6.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "MediShield\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MediShield\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite Unit",
        "test:integration": "phpunit --testsuite Integration"
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
